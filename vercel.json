{
  "framework": null,
  "buildCommand": "pnpm install && node build-vercel.mjs",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/handler" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/handler.mjs": {
      "memory": 512,
      "maxDuration": 30
    }
  }
}
